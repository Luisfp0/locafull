# =============================================================================
# Locafull — copie para .env.local e preencha os valores
# Arquivo de exemplo (sem segredos reais). .env.local não vai pro Git.
#
# Ao alternar LOCAL ↔ simular PRODUÇÃO no PC:
#   1. Troque NEXT_PUBLIC_SITE_URL (um bloco ativo)
#   2. Reinicie: pnpm dev
#
# Testar fluxo completo em produção: use locafull.vercel.app (variáveis na Vercel).
# =============================================================================

# --- Site (escolha UM) -------------------------------------------------------
# LOCAL — pnpm dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# PRODUÇÃO — só se for testar build/checkout apontando pro domínio publicado
# NEXT_PUBLIC_SITE_URL=https://locafull.vercel.app

# --- Contato / redes (iguais em local e prod) --------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=556230300077
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/locafull_locacoes/

# --- AbacatePay (Pix transparente + cartão hospedado) ------------------------
# Chave de API (dev ou produção — o ambiente é definido pela chave).
ABACATEPAY_API_KEY=
# Secret do webhook (vai na query string ?webhookSecret=...).
ABACATEPAY_WEBHOOK_SECRET=
# Opcional: sobrescrever a chave pública HMAC (default: constante da doc Abacate).
# ABACATEPAY_WEBHOOK_HMAC_KEY=

# --- Webhook local -----------------------------------------------------------
# A AbacatePay chama uma URL pública. Em dev, use um túnel (ngrok/cloudflare)
# apontando para /api/abacatepay/webhook?webhookSecret=... ou simule o
# pagamento Pix no dev-mode da AbacatePay.

# --- Supabase (mesmo projeto em local e prod) --------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=

# --- Trello (card na coluna ENTREGAR após pagamento confirmado) --------------
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_MAX_DELIVERIES_PER_DAY=6
TRELLO_LIST_ID_A_AGENDAR=
TRELLO_LABEL_ID_ENTREGAR=
