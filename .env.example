# =============================================================================
# Locafull — copie para .env.local e preencha os valores
# Arquivo de exemplo (sem segredos reais). .env.local não vai pro Git.
#
# Ao alternar LOCAL ↔ simular PRODUÇÃO no PC:
#   1. Troque NEXT_PUBLIC_SITE_URL (um bloco ativo)
#   2. Troque STRIPE_WEBHOOK_SECRET (uma linha ativa)
#   3. Reinicie: pnpm dev
#
# Testar fluxo completo em produção: use locafull.vercel.app (variáveis na Vercel).
# =============================================================================

# --- Site (escolha UM) -------------------------------------------------------
# LOCAL — pnpm dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# PRODUÇÃO — só se for testar build/checkout apontando pro domínio publicado
# NEXT_PUBLIC_SITE_URL=https://locafull.vercel.app

# --- Contato / redes (iguais em local e prod) --------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=556230300077
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/locafull_locacoes/

# --- Stripe (modo teste — mesmas chaves sk_test/pk_test em local e Vercel) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PAYMENT_METHODS=card

# --- Stripe webhook (escolha UM) ---------------------------------------------
# LOCAL — rode em outro terminal:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# Use o whsec_ que o comando imprimir (muda se rodar listen de novo).
STRIPE_WEBHOOK_SECRET=

# PRODUÇÃO — Stripe Dashboard → Webhooks → locafull.vercel.app → Signing secret
# (na Vercel, não aqui — salvo se quiser simular prod no PC)
# STRIPE_WEBHOOK_SECRET=

# --- Supabase (mesmo projeto em local e prod) --------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=

# --- Trello (card em "A agendar" após pagamento confirmado) ------------------
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID_A_AGENDAR=
TRELLO_LABEL_ID_ENTREGAR=
